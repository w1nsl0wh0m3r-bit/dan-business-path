  if (t.status === 'watch') return 'watchlist';
  const entry = (t.entry_path || '').toLowerCase();
  const name = (t.name || '').toLowerCase();
  if (entry.includes('acqui') || entry.includes('buy')) return 'acquisition_target';
  if (entry.includes('jv') || entry.includes('partner')) return 'jv_candidate';
  if (name.includes('franchisee') || name.includes('territor') || entry.includes('franchise')) return 'franchise_rights';
  return 'operating_target';
}

TARGETS.forEach(t => {
  Object.assign(t, PIPELINE_OVERRIDES[t.id] || {});
  t.sources = Array.isArray(t.sources) ? t.sources : (t.sources ? [t.sources] : []);
  t.buzz_signals = Array.isArray(t.buzz_signals) ? t.buzz_signals : (t.buzz_signals ? [t.buzz_signals] : []);
  t.pipeline_type = inferPipelineType(t);
  t.evidence_state = t.evidence_state || (hasPublicSource(t) ? 'verified_public' : ((t.sources || []).length ? 'internal_only' : 'unsupported'));
  t.last_verified = t.last_updated || null;
  t.next_action = t.next_action || (t.first_diligence && !/^n\/?a/i.test(t.first_diligence) ? t.first_diligence : (t.status === 'comp' ? 'Retain as benchmark; no pursuit.' : t.status === 'watch' ? 'Verify units, ownership, buzz and economics.' : 'Complete public-evidence screen before any outreach.'));
});

const CATEGORY_COLORS = {"Bagels": "#8B6914", "Bakery": "#D4A574", "Swedish Candy": "#FF6B9D", "Frozen Dessert": "#A8D8EA", "Food & Beverage": "#FF8C42", "Fast Casual": "#E8743B", "Beverage": "#6B8E23", "Pet Services": "#4A90D9", "Auto Services": "#6B6B6B", "Youth Sports & Kids": "#50C878", "Boutique Fitness": "#FF6347", "Med Spa & Wellness": "#DDA0DD", "Beauty & Aesthetics": "#FF69B4", "Experiential Entertainment": "#9370DB", "Home Technology Services": "#708090", "Social Bathhouse": "#20B2AA", "Padel & Racquet Social": "#00CED1", "Luxury Repair & Circular Care": "#DAA520", "Tabletop & Hobby Social": "#8B4513", "Plant Workshop & Retail": "#228B22", "Kids Haircuts & Family Grooming": "#FFB347", "Aging-in-Place & Mobility": "#B0C4DE", "GLP-1 & Weight-Loss Services": "#FF1493", "Non-Alcoholic & Sober Social": "#7B68EE", "Drive-Thru Coffee": "#8B4513", "Pilates Reformer & Boutique": "#C71585", "IV Hydration & Recovery": "#00BFFF"};
let currentSort = { key: 'conviction_score', dir: 'desc' };
let filtered = [...TARGETS];

function convictionColor(s) {
  if (s >= 8) return '#22c55e';
  if (s >= 5) return '#eab308';
  return '#ef4444';
}

function urgencyBadge(u) {
  if (u === 'high') return '<span class="urgency-high">⚡ HIGH</span>';
  if (u === 'medium') return '<span class="urgency-medium">◐ MED</span>';
  return '';
}

function confidenceBadge(c) {
  const cls = c === 'high' ? 'confidence-high' : c === 'medium' ? 'confidence-medium' : 'confidence-low';
  return `<span class="confidence-badge ${cls}">${c}</span>`;
}

function evidenceBadge(state) {
  const labels = { verified_public: '✓ public', internal_only: '◐ internal', unsupported: '! unsupported' };
  return `<span class="evidence-badge evidence-${state}">${labels[state] || state}</span>`;
}

function pipelineLabel(type) {
  return (type || '').replaceAll('_', ' ');
}

function sourceMarkup(source) {
  if (/^https?:\/\//i.test(source)) return `<a href="${source}" target="_blank" rel="noopener">${source.substring(0,72)}${source.length > 72 ? '…' : ''}</a>`;
  return `<span>${source}</span>`;
}

function updateDashboardSummary() {
  const targets = TARGETS.filter(t => t.status === 'target').length;
  const watch = TARGETS.filter(t => t.status === 'watch').length;
  const comps = TARGETS.filter(t => t.status === 'comp').length;
  const sourced = TARGETS.filter(hasPublicSource).length;
  document.getElementById('sumEntries').textContent = TARGETS.length;
  document.getElementById('sumTargets').textContent = targets;
  document.getElementById('sumWatch').textContent = watch;
  document.getElementById('sumComps').textContent = comps;
  document.getElementById('sumSourced').textContent = `${Math.round(100 * sourced / TARGETS.length)}%`;
  document.getElementById('sumNeedsEvidence').textContent = TARGETS.length - sourced;
  document.getElementById('subtitleLine').textContent = `V3 — Operator-grade pipeline · ${TARGETS.length} entries across ${Object.keys(CATEGORY_COLORS).length} categories · Evidence audited 2026-07-19`;

  const counts = TARGETS.reduce((acc, t) => ((acc[t.category] = (acc[t.category] || 0) + 1), acc), {});
  document.getElementById('categoryLegend').innerHTML = Object.entries(counts).sort((a,b) => b[1] - a[1] || a[0].localeCompare(b[0])).map(([category, count]) =>
    `<span class="legend-item" style="border-color:${CATEGORY_COLORS[category] || '#888'}">${category} <b>(${count})</b></span>`
  ).join('');
}

// ===== TABLE =====
function renderTable() {
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = filtered.map((t, i) => `
    <tr onclick="toggleDetail('detail-${i}')" style="cursor:pointer">
      <td class="conviction-cell" style="color:${convictionColor(t.conviction_score)}">${t.conviction_score}</td>
      <td><b>${t.name}</b></td>
      <td><span class="cat-dot" style="background:${CATEGORY_COLORS[t.category]||'#888'}"></span>${t.category}</td>
      <td><span class="status-badge status-${t.status}">${t.status}</span></td>
      <td><span class="pipeline-badge">${pipelineLabel(t.pipeline_type)}</span></td>
      <td>${evidenceBadge(t.evidence_state)}</td>
      <td>${t.units || '—'}</td>
      <td class="financial">$${t.check_size_k}K</td>
      <td style="text-align:center">${'⭐'.repeat(t.cash_on_cash_potential)}</td>
      <td>${t.time_to_revenue_months}mo</td>
      <td>${t.est_payback_months}mo</td>
      <td>${urgencyBadge(t.urgency)}</td>
      <td>${t.hq_city || '—'}</td>
    </tr>
    <tr class="detail-row" id="detail-${i}">
      <td colspan="13">
        <div class="detail-content">
          <div class="detail-section">
            <h4>Story</h4>
            <p>${t.story}</p>
            <h4>Traction</h4>
            <p>${t.traction || '—'}</p>
            <h4>Entry Path</h4>
            <p>${t.entry_path || '—'}</p>
            <h4>Pipeline Classification</h4>
            <p>${pipelineLabel(t.pipeline_type)} · ${evidenceBadge(t.evidence_state)} · Last verified: ${t.last_verified || 'not recorded'}</p>
            <h4>Next Action</h4>
            <p>${t.next_action}</p>
            <h4>Dan's Value Add</h4>
            <p>${t.dan_value_add || '—'}</p>
          </div>
          <div class="detail-section">
            <h4>Financial Proxy</h4>
            <p>
              <span class="field">Revenue:</span> $${t.est_revenue_low_k}–${t.est_revenue_high_k}K/unit<br>
              <span class="field">Margin:</span> ${t.est_margin_pct}%<br>
              <span class="field">SDE:</span> $${t.est_sde_low_k}–${t.est_sde_high_k}K/unit<br>
              <span class="field">Capex/Unit:</span> $${t.est_capex_per_unit_k}K<br>
              <span class="field">Payback:</span> ${t.est_payback_months}mo<br>
              <span class="field">Confidence:</span> ${confidenceBadge(t.model_confidence)}
            </p>
            <h4>First Diligence</h4>
            <p>${t.first_diligence || '—'}</p>
            <h4>Buzz Signals</h4>
            <p>${(t.buzz_signals||[]).join('<br>• ') || '—'}</p>
            ${t.sources && t.sources.length ? `<h4>Sources</h4><p>${t.sources.map(sourceMarkup).join('<br>')}</p>` : '<h4>Sources</h4><p>None recorded — evidence gap.</p>'}
          </div>
        </div>
      </td>
    </tr>
  `).join('');
}

function toggleDetail(id) {
  const row = document.getElementById(id);
  if (row) row.classList.toggle('visible');
}

// ===== SORT =====
function sortTable(key) {
  if (currentSort.key === key) {
    currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
  } else {
    currentSort.key = key;
    currentSort.dir = key === 'name' || key === 'category' || key === 'status' || key === 'hq_city' || key === 'urgency' ? 'asc' : 'desc';
  }
  applyFilters();
  // Update header indicators
  document.querySelectorAll('th').forEach(th => th.classList.remove('sorted-asc', 'sorted-desc'));
}

// ===== FILTERS =====
function applyFilters() {
  const status = document.getElementById('filterStatus').value;
  const category = document.getElementById('filterCategory').value;
  const checkRange = document.getElementById('filterCheck').value;
  const evidence = document.getElementById('filterEvidence').value;
  const search = document.getElementById('searchBox').value.toLowerCase();

  filtered = TARGETS.filter(t => {
    if (status && t.status !== status) return false;
    if (category && t.category !== category) return false;
    if (evidence && t.evidence_state !== evidence) return false;
    if (checkRange) {
      const [lo, hi] = checkRange.split('-').map(Number);
      if (t.check_size_k < lo || t.check_size_k > hi) return false;
    }
    if (search) {
      const hay = (t.name + t.category + t.story + t.pipeline_type + t.evidence_state + t.next_action + (t.buzz_signals||[]).join(' ')).toLowerCase();
      if (!hay.includes(search)) return false;
    }
    return true;
  });

  // Sort
  const key = currentSort.key;
  const dir = currentSort.dir === 'asc' ? 1 : -1;
  filtered.sort((a, b) => {
    let va = a[key], vb = b[key];
    if (typeof va === 'string') return va.localeCompare(vb) * dir;
    return (va - vb) * dir;
  });

  renderTable();
  if (document.getElementById('mapView').classList.contains('active')) updateMap();
}

// ===== VIEWS =====
function showView(view) {
  document.querySelectorAll('.content').forEach(c => c.classList.remove('active'));
  document.querySelectorAll('.toolbar button').forEach(b => b.classList.remove('active'));
  if (view === 'table') {
    document.getElementById('tableView').classList.add('active');
    document.getElementById('btnTable').classList.add('active');
  } else if (view === 'map') {
    document.getElementById('mapView').classList.add('active');
    document.getElementById('btnMap').classList.add('active');
    if (!map._loaded) initMap();
    setTimeout(() => map.invalidateSize(), 100);
  } else if (view === 'rank') {
    document.getElementById('rankView').classList.add('active');
    document.getElementById('btnRank').classList.add('active');
    renderRankings();
  }
}

// ===== RANKINGS =====
function renderRankings() {
  const targets = TARGETS.filter(t => t.status === 'target');

  // Top 20 by conviction
  const byConviction = [...targets].sort((a,b) => b.conviction_score - a.conviction_score);
  document.getElementById('rankConviction').innerHTML = byConviction.slice(0,20).map((t,i) =>
    `<tr><td class="rank-num">${i+1}</td><td><b>${t.name}</b></td><td>${t.category}</td><td style="color:${convictionColor(t.conviction_score)};font-weight:700;text-align:center">${t.conviction_score}</td><td>${'⭐'.repeat(t.cash_on_cash_potential)}</td><td>$${t.check_size_k}K</td><td>${urgencyBadge(t.urgency)}</td></tr>`
  ).join('');

  // Top 10 fast money (CoC / time_to_revenue)
  const byFast = [...targets].sort((a,b) => (b.cash_on_cash_potential/a.time_to_revenue_months) - (a.cash_on_cash_potential/a.time_to_revenue_months));
  document.getElementById('rankFast').innerHTML = byFast.slice(0,10).map((t,i) =>
    `<tr><td class="rank-num">${i+1}</td><td><b>${t.name}</b></td><td>${t.category}</td><td>${'⭐'.repeat(t.cash_on_cash_potential)}</td><td>${t.time_to_revenue_months}mo</td><td>${t.est_payback_months}mo</td></tr>`
  ).join('');

  // Top 10 urgent
  const byUrgent = [...targets].filter(t => t.urgency === 'high').sort((a,b) => b.conviction_score - a.conviction_score);
  document.getElementById('rankUrgent').innerHTML = byUrgent.slice(0,10).map((t,i) =>
    `<tr><td class="rank-num">${i+1}</td><td><b>${t.name}</b></td><td>${t.category}</td><td style="color:${convictionColor(t.conviction_score)};font-weight:700;text-align:center">${t.conviction_score}</td><td>${(t.story||'').substring(0,100)}...</td></tr>`
  ).join('');

  // Bottom 20 kill list
  const byKill = [...TARGETS].sort((a,b) => a.conviction_score - b.conviction_score);
  document.getElementById('rankKill').innerHTML = byKill.slice(0,20).map((t,i) =>
    `<tr><td class="rank-num">${i+1}</td><td>${t.name}</td><td>${t.category}</td><td style="color:${convictionColor(t.conviction_score)};font-weight:700;text-align:center">${t.conviction_score}</td><td><span class="status-badge status-${t.status}">${t.status}</span></td></tr>`
  ).join('');
}

// ===== MAP =====
let map, markerLayer;
function initMap() {
  map = L.map('map').setView([39.5, -98.35], 4);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap', maxZoom: 19
  }).addTo(map);
  markerLayer = L.layerGroup().addTo(map);
  map._loaded = true;
  updateMap();
}

function updateMap() {
  if (!markerLayer) return;
  markerLayer.clearLayers();
  filtered.filter(t => t.lat && t.lng).forEach(t => {
    const color = t.status === 'target' ? convictionColor(t.conviction_score) : t.status === 'watch' ? '#eab308' : '#6b7280';
    const marker = L.circleMarker([t.lat, t.lng], {
      radius: t.status === 'target' ? Math.max(6, t.conviction_score) : 5,
      fillColor: color, color: '#000', weight: 1, fillOpacity: 0.8
    });
    marker.bindPopup(`
      <div style="font-family:sans-serif;min-width:200px">
        <b>${t.name}</b><br>
        <span style="color:${color}">${t.status} · Conviction ${t.conviction_score}</span><br>
        <small>${t.category}</small><br>
        <small>${pipelineLabel(t.pipeline_type)} · ${t.evidence_state.replaceAll('_', ' ')}</small><br>
        <small>Check: $${t.check_size_k}K · CoC: ${'⭐'.repeat(t.cash_on_cash_potential)}</small><br><br>
        <small>${(t.story||'').substring(0,150)}</small>
      </div>
    `);
    marker.addTo(markerLayer);
  });
}

// Init
updateDashboardSummary();
applyFilters();
</script>
</body>
</html>
