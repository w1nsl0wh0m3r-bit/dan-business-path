<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root {
  --paper: #0d1117;
  --paper2: #161b22;
  --paper3: #21262d;
  --text: #e6edf3;
  --muted: #8b949e;
  --line: #30363d;
  --accent: #58a6ff;
  --green: #22c55e;
  --yellow: #eab308;
  --red: #ef4444;
  --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--paper); color: var(--text); font-family: var(--font); font-size: 14px; line-height: 1.5; }

/* Summary cards */
.summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; padding: 16px 20px; }
.summary-card { background: var(--paper2); border: 1px solid var(--line); border-radius: 10px; padding: 16px; text-align: center; }
.summary-card .num { font-size: 32px; font-weight: 800; letter-spacing: -0.03em; }
.summary-card .label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }

/* Toolbar */
.toolbar { display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 20px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--paper2); position: sticky; top: 0; z-index: 100; }
.toolbar button, .toolbar select { background: var(--paper3); color: var(--text); border: 1px solid var(--line); border-radius: 6px; padding: 8px 14px; font-size: 13px; cursor: pointer; font-family: var(--font); }
.toolbar button:hover { border-color: var(--accent); }
.toolbar button.active { background: var(--accent); color: #000; border-color: var(--accent); }
.toolbar select { padding: 7px 10px; }
.toolbar .spacer { flex: 1; }
.toolbar input[type="search"] { background: var(--paper3); color: var(--text); border: 1px solid var(--line); border-radius: 6px; padding: 8px 12px; font-size: 13px; width: 200px; font-family: var(--font); }

/* Map + Table layout */
.content { display: none; padding: 0; }
.content.active { display: block; }

/* Map */
#mapView { height: calc(100vh - 200px); width: 100%; }
#map { height: 100%; width: 100%; }
.map-detail { position: fixed; top: 200px; right: 20px; width: 360px; max-height: 500px; overflow-y: auto; background: var(--paper2); border: 1px solid var(--line); border-radius: 10px; padding: 0; z-index: 200; display: none; }
.map-detail.visible { display: block; }
.map-detail-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--line); position: sticky; top: 0; background: var(--paper2); }
.map-detail-body { padding: 16px; }
.map-detail h3 { font-size: 18px; }
.map-detail .close-btn { cursor: pointer; color: var(--muted); font-size: 20px; }

/* Table */
.table-wrap { overflow-x: auto; padding: 0 20px 40px; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { background: var(--paper2); text-align: left; padding: 10px 12px; border-bottom: 2px solid var(--line); cursor: pointer; white-space: nowrap; position: sticky; top: 0; font-weight: 600; color: var(--muted); text-transform: uppercase; font-size: 11px; letter-spacing: 0.05em; }
th:hover { color: var(--accent); }
th.sorted-asc::after { content: ' ↑'; color: var(--accent); }
th.sorted-desc::after { content: ' ↓'; color: var(--accent); }
td { padding: 8px 12px; border-bottom: 1px solid var(--line); }
tr:hover { background: var(--paper2); }
.conviction-cell { font-weight: 700; text-align: center; font-size: 15px; }
.urgency-high { color: var(--red); font-weight: 700; font-size: 11px; }
.urgency-medium { color: var(--yellow); font-weight: 600; font-size: 11px; }
.status-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.pipeline-badge, .evidence-badge { display: inline-block; padding: 2px 7px; border-radius: 999px; font-size: 10px; font-weight: 700; white-space: nowrap; }
.pipeline-badge { color: #cbd5e1; background: #1e293b; border: 1px solid #334155; }
.evidence-verified_public { color: #86efac; background: #052e16; }
.evidence-internal_only { color: #fde68a; background: #422006; }
.evidence-unsupported { color: #fca5a5; background: #450a0a; }
.status-target { background: rgba(34,197,94,0.15); color: var(--green); }
.status-watch { background: rgba(234,179,8,0.15); color: var(--yellow); }
.status-comp { background: rgba(139,148,158,0.15); color: var(--muted); }
.cat-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; }

/* Legend */
.legend { display: flex; flex-wrap: wrap; gap: 8px; padding: 8px 20px 16px; }
.legend-item { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; color: var(--muted); border-left: 3px solid; padding-left: 6px; }
.legend-item b { color: var(--text); }

/* Detail panel (table) */
.detail-row { display: none; }
.detail-row.visible { display: table-row; background: var(--paper3) !important; }
.detail-row td { padding: 16px; }
.detail-content { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; font-size: 12px; }
.detail-section h4 { font-size: 12px; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
.detail-section p { color: var(--text); margin-bottom: 8px; line-height: 1.6; }
.detail-section .field { color: var(--muted); }

/* Financial cells */
.financial { font-family: 'SF Mono', Monaco, monospace; font-size: 12px; color: var(--accent); }
.financial-low { color: var(--muted); }

/* Confidence badge */
.confidence-badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; font-weight: 600; }
.confidence-high { background: rgba(34,197,94,0.15); color: var(--green); }
.confidence-medium { background: rgba(234,179,8,0.15); color: var(--yellow); }
.confidence-low { background: rgba(239,68,68,0.15); color: var(--red); }

/* Header */
header { padding: 20px 20px 0; }
header h1 { font-size: 24px; font-weight: 800; letter-spacing: -0.03em; }
header .subtitle { color: var(--muted); font-size: 14px; margin-top: 4px; }

/* Ranking cards */
.rank-section { padding: 20px; }
.rank-section h2 { font-size: 18px; margin-bottom: 12px; }
.rank-card { background: var(--paper2); border: 1px solid var(--line); border-radius: 10px; padding: 16px; margin-bottom: 16px; }
.rank-card table { font-size: 12px; }
.rank-card th { font-size: 10px; }
.rank-card td { padding: 6px 10px; }
.rank-num { font-weight: 800; font-size: 14px; width: 30px; }

/* Mobile */
@media (max-width: 768px) {
  .summary-grid { grid-template-columns: repeat(2, 1fr); }
  .toolbar { position: static; }
  .map-detail { position: static; width: 100%; max-height: none; margin: 16px 20px; }
  .detail-content { grid-template-columns: 1fr; }
  table { font-size: 12px; }
  th, td { padding: 6px 8px; }
}
</style>
</head>
